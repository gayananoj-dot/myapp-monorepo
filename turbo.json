{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": { "cache": true },
    "typecheck": { "cache": true },
    "test": { "cache": true },
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    }
  }
}